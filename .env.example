# BuildCore Release Tool — environment variables.
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored. Do not commit secrets.

# -------- Password gate ----------------------------------------------------
# Required. The shared password for the unlock screen. Pick any string.
GATE_PASSWORD=

# -------- Supabase --------------------------------------------------------
# From your Supabase project settings → API.
# These point to the NEW Release Tool Supabase project — not bid-sheet-v2.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by API routes (webhooks, server-side queries).
# NEVER commit this. NEVER expose to the browser. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# -------- Webhooks -------------------------------------------------------
# Shared secret for Evan's agent posting ticket updates. Any random string.
TICKETS_WEBHOOK_SECRET=

# GitHub webhook secret (configured per webhook in the bid-sheet-v2 repo).
GITHUB_WEBHOOK_SECRET=

# BuildCore portal feedback intake secret.
FEEDBACK_WEBHOOK_SECRET=
